}
.ds-mob-link:hover {
  color: var(--color-primary);
}

/* Rich карточка Жильё (mobile) */
.ds-mob-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
