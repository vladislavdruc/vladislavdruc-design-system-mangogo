/* ==========================================
   .ds-header — MangoGo Navbar
   Tilda T123
   ========================================== */

.ds-header {
  position: relative;
  width: 100%;
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  font-family: var(--font-body);
  z-index: 1000;
}

.ds-header__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-8);
  height: 72px;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

/* ── Logo ── */
.ds-header__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
}
.ds-header__logo img {
  height: 36px;
  width: auto;
  display: block;
}

/* ── Desktop nav ── */
.ds-header__nav {
  flex: 1;
  display: flex;
  justify-content: center;
}
.ds-header__list {
  list-style: none;
  margin: 0;
  margin-bottom: 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: var(--space-1);
}
.ds-header__item {
  position: relative;
}

.ds-header__link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  height: 38px;
  font-family: var(--font-body);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-black);
  text-decoration: none;
  background: none;
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  white-space: nowrap;
  line-height: 1;
  transition: color var(--transition-base), background var(--transition-base), padding var(--transition-base);
}
.ds-header__link:hover {
  color: var(--color-brand-500);
}
.ds-header__link .ds-chev {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  transition: transform var(--transition-base);
}

/* Жильё и Ещё — hover и открытое состояние */
#nav-zhilye > .ds-header__link:hover,
#nav-eshe   > .ds-header__link:hover {
  padding: var(--space-3) var(--space-6);
  background: var(--color-black);
  color: var(--color-text-inverse);
}

.ds-header__item.is-open > .ds-header__link {
  padding: var(--space-3) var(--space-6);
  background: var(--color-black);
  color: var(--color-text-inverse);
}
.ds-header__item.is-open > .ds-header__link:hover {
  color: var(--color-text-inverse);
}
.ds-header__item.is-open > .ds-header__link .ds-chev {
  transform: rotate(180deg);
}

/* ── Dropdown ── */
.ds-header__drop {
  display: none;
  position: absolute;
  top: calc(100% + var(--space-3));
  background: var(--color-black);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-2xl);
  padding: var(--space-3);
  z-index: 200;
}
.ds-header__item.is-open .ds-header__drop {
  display: block;
}
.ds-header__drop--rich {
  left: 0;
  width: 320px;
}
.ds-header__drop--simple {
  right: 0;
  width: 260px;
}

/* Rich item */
.ds-ddi {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-3);
  border-radius: var(--radius-xl);
  text-decoration: none;
  transition: filter var(--transition-base);
}
.ds-ddi:hover {
  /* ⚠️ нет токена --color-black-hover, использован filter */
  filter: brightness(1.35);
}
.ds-ddi__icon {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
  color: var(--color-primary);
  margin-top: 2px;
}
.ds-ddi__title {
  font-size: var(--text-md);
  font-weight: var(--fw-semibold);
  color: var(--color-text-inverse);
  line-height: 1.3;
  margin-bottom: var(--space-1);
}
.ds-ddi__desc {
  font-size: var(--text-sm);
  font-weight: var(--fw-regular);
  color: var(--color-text-faint);
  line-height: 1.45;
}

/* Simple link */
.ds-ddl {
  display: block;
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-text-inverse);
  text-decoration: none;
  border-radius: var(--radius-xl);
  transition: filter var(--transition-base);
}
.ds-ddl:hover {
  color: var(--color-text-inverse);
  /* ⚠️ нет токена --color-black-hover, использован filter */
  filter: brightness(1.35);
}

/* ── CTA ── */
.ds-header__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0 var(--space-5);
  height: 40px;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: var(--fw-semibold);
  color: var(--color-text-inverse);
  background: var(--color-accent);
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: filter var(--transition-base);
}
.ds-header__cta:hover {
  /* ⚠️ нет токена --color-accent-hover в системе, использован filter */
  filter: brightness(0.9);
}
.ds-header__cta svg {
  width: 15px;
  height: 15px;
  flex-shrink: 0;
}

/* ── Бургер ── */
.ds-header__burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  margin-left: auto;
  transition: background var(--transition-base);
}
.ds-header__burger:hover {
  background: var(--color-surface-2);
}
.ds-burger-ln {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-text);
  border-radius: var(--radius-full);
}

/* ==========================================
   Overlay + Drawer
   ========================================== */
.ds-header__overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: var(--color-black);
  opacity: 0;
  z-index: 800;
  transition: opacity var(--transition-base);
  pointer-events: none;
}
.ds-header__overlay.is-visible {
  display: block;
  opacity: 0.5;
  pointer-events: auto;
}

.ds-header__drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: 75vw;
  max-width: 400px;
  height: 100vh;
  background: var(--color-bg);
  z-index: 900;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform var(--transition-slow);
  overflow: hidden;
}
.ds-header__drawer.is-open {
  transform: translateX(0);
}

/* Шапка drawer */
.ds-drw-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-5);
  height: 64px;
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}
.ds-drw-top .ds-header__cta {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  height: 38px;
  padding: 0 var(--space-4);
  filter: none;
}
.ds-drw-top .ds-header__cta:hover {
  background: var(--color-primary-hover);
  filter: none;
}

.ds-drw-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text);
  border-radius: var(--radius-md);
  transition: background var(--transition-base);
}
.ds-drw-close:hover {
  background: var(--color-surface-2);
}
.ds-drw-close svg {
  width: 22px;
  height: 22px;
}

/* Скролл-область */
.ds-drw-body {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-2) 0 var(--space-8);
}

/* ── Аккордеон ── */
.ds-acc-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: var(--space-4) var(--space-5);
  font-family: var(--font-body);
  font-size: var(--text-xl);
  font-weight: var(--fw-semibold);
  color: var(--color-text);
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  min-height: 56px;
  transition: color var(--transition-base);
}
.ds-acc-trigger:hover {
  color: var(--color-primary);
}
.ds-acc-trigger svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  transition: transform var(--transition-base);
}
.ds-acc-item.is-open .ds-acc-trigger svg {
  transform: rotate(180deg);
}
.ds-acc-body {
  display: none;
  padding: 0 var(--space-5) var(--space-4);
}
.ds-acc-item.is-open .ds-acc-body {
  display: block;
}

/* Обычная ссылка в drawer */
.ds-mob-link {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  font-family: var(--font-body);
  font-size: var(--text-xl);
