}
.ds-mob-card-icon {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
  color: var(--color-primary);
  margin-top: 2px;
}
.ds-mob-card-title {
  font-size: var(--text-md);
  font-weight: var(--fw-bold);
  color: var(--color-text);
  margin-bottom: var(--space-1);
  line-height: 1.3;
}
.ds-mob-card-desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.45;
}

/* Простые ссылки Ещё (mobile) */
.ds-mob-slink {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-text);
  text-decoration: none;
  border-radius: var(--radius-md);
  min-height: 44px;
  transition: color var(--transition-base), background var(--transition-base);
}
.ds-mob-slink:hover {
  color: var(--color-primary);
  background: var(--color-primary-surface-sm);
}

/* ── Адаптив ── */
@media (max-width: 960px) {
  .ds-header__nav,
  .ds-header__cta {
    display: none;
  }
  .ds-header__burger {
    display: flex;
  }
}
@media (max-width: 480px) {
  .ds-header__inner {
    padding: 0 var(--space-4);
    height: 64px;
  }
  .ds-header__drawer {
    width: 100vw;
    max-width: 100vw;
  }
}

/* ── ПРАВКИ ── */

