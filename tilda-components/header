  background: transparent;
}
.ds-mob-card-item + .ds-mob-card-item {
  border-top: 1px solid var(--color-border);
}
.ds-mob-card-item:hover {
  background: var(--color-surface) !important;
}
/* Правка 9: убираем статичный is-active hover-стиль */
.ds-mob-card-item.is-active {
  background: transparent;
}
.ds-mob-card-item.is-active:hover {
  background: var(--color-surface) !important;
}
.ds-mob-card-icon {
  width: 32px !important;
  height: 32px !important;
  min-width: 32px !important;
  min-height: 32px !important;
  max-width: 32px !important;
  max-height: 32px !important;
  flex-shrink: 0;
  color: var(--color-primary);
  margin-top: 2px;
}
.ds-mob-card-title {
  font-size: var(--text-md);
  font-weight: var(--fw-bold);
  color: var(--color-text);
  margin-bottom: var(--space-1);
  line-height: 1.3;
}
.ds-mob-card-desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.45;
}

/* Простые ссылки Ещё (mobile) */
.ds-drw-body .ds-mob-slink,
.ds-drw-body .ds-mob-slink:link,
.ds-drw-body .ds-mob-slink:visited {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-text) !important;
  text-decoration: none !important;
  border-radius: var(--radius-md);
  min-height: 44px;
  transition: color var(--transition-base) !important, background var(--transition-base);
}
.ds-drw-body .ds-mob-slink:hover {
  color: var(--color-primary) !important;
  background: var(--color-primary-surface-sm);
}

/* ── Адаптив ── */
@media (max-width: 960px) {
  .ds-header__nav,
  /* Скрываем десктопный CTA */
  .ds-header__inner > .ds-header__cta {
    display: none;
  }
  .ds-header__burger {
    display: flex;
  }
  /* Правка 5: показываем мобильный CTA */
  .ds-header__cta--mobile-inner {
    display: inline-flex;
    margin-left: auto;
  }
}
@media (max-width: 480px) {
