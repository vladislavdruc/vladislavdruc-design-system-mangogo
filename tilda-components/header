<script>
(function () {
  var hdr      = document.getElementById('ds-header');
  var burger   = document.getElementById('ds-burger');
  var overlay  = document.getElementById('ds-overlay');
  var drawer   = document.getElementById('ds-drawer');
  var closeBtn = document.getElementById('ds-drw-close');

  if (!hdr || !burger || !overlay || !drawer || !closeBtn) { return; }

  /* ── Tilda link color fix — run at 3 points ── */
  function fixLinkColors() {
    /* Nav links (не Жильё/Ещё) */
    hdr.querySelectorAll('.ds-header__nav .ds-header__item:not(#nav-zhilye):not(#nav-eshe) a.ds-header__link').forEach(function(a) {
      a.style.setProperty('color', 'var(--color-text-link)', 'important');
      a.style.setProperty('text-decoration', 'none', 'important');
    });
    /* Dropdown --simple */
    hdr.querySelectorAll('.ds-header__drop--simple .ds-ddl').forEach(function(a) {
      a.style.setProperty('color', 'var(--color-text-inverse)', 'important');
      a.style.setProperty('text-decoration', 'none', 'important');
    });
    /* Dropdown --rich */
    hdr.querySelectorAll('.ds-header__drop--rich .ds-ddi').forEach(function(a) {
      a.style.setProperty('text-decoration', 'none', 'important');
    });
    /* CTA */
    hdr.querySelectorAll('a.ds-header__cta').forEach(function(a) {
      a.style.setProperty('color', 'var(--color-text-inverse)', 'important');
      a.style.setProperty('text-decoration', 'none', 'important');
    });
    /* Mob links */
    hdr.querySelectorAll('.ds-mob-link, .ds-mob-card-item, .ds-mob-slink').forEach(function(a) {
      a.style.setProperty('text-decoration', 'none', 'important');
    });
  }
  fixLinkColors();
  document.addEventListener('DOMContentLoaded', fixLinkColors);
  window.addEventListener('load', fixLinkColors);

  /* ── Hover для Tilda-overridden ссылок (правка 1) ── */
  hdr.querySelectorAll('.ds-header__nav .ds-header__item:not(#nav-zhilye):not(#nav-eshe) a.ds-header__link').forEach(function(a) {
    a.addEventListener('mouseenter', function() {
      a.style.setProperty('color', 'var(--color-brand-500)', 'important');
    });
    a.addEventListener('mouseleave', function() {
      a.style.setProperty('color', 'var(--color-text-link)', 'important');
    });
  });

  /* ── Drawer ── */
  function openDrawer() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-visible');
    overlay.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
  }
  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-visible');
    overlay.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
  }

  burger.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  /* ── Dropdowns с задержкой закрытия ── */
  var CLOSE_DELAY = 180;

  function closeItem(item) {
    if (!item) { return; }
    item.classList.remove('is-open');
    var t = item.querySelector('.ds-header__link');
    if (t) { t.setAttribute('aria-expanded', 'false'); }
  }

  var ddItems = [
    document.getElementById('nav-zhilye'),
    document.getElementById('nav-eshe')
  ];

  ddItems.forEach(function (item) {
    if (!item) { return; }
    var trigger = item.querySelector('.ds-header__link');
    var closeTimer = null;

    function cancelClose() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    }
    function scheduleClose() {
      cancelClose();
      closeTimer = setTimeout(function() { closeItem(item); }, CLOSE_DELAY);
    }

    item.addEventListener('mouseenter', function () {
      cancelClose();
      ddItems.forEach(function (o) { if (o !== item) { closeItem(o); } });
      item.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('mouseleave', function () {
      scheduleClose();
    });

    var drop = item.querySelector('.ds-header__drop');
    if (drop) {
      drop.addEventListener('mouseenter', function () { cancelClose(); });
      drop.addEventListener('mouseleave', function () { scheduleClose(); });
    }

    trigger.addEventListener('click', function (e) {
      e.preventDefault();
      cancelClose();
      var isOpen = item.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        ddItems.forEach(function (o) { if (o !== item) { closeItem(o); } });
      }
    });
  });

  document.addEventListener('click', function (e) {
    if (!hdr.contains(e.target)) { ddItems.forEach(closeItem); }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { ddItems.forEach(closeItem); closeDrawer(); }
  });

  /* ── Accordion ── */
  hdr.querySelectorAll('.ds-acc-item').forEach(function (acc) {
    var trig = acc.querySelector('.ds-acc-trigger');
    if (!trig) { return; }
    trig.addEventListener('click', function () {
      var isOpen = acc.classList.toggle('is-open');
      trig.setAttribute('aria-expanded', String(isOpen));
    });
  });
})();
</script>
