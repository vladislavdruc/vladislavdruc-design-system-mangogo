<style>
/* ==========================================
   .ds-header — MangoGo Navbar
   Tilda T123
   ========================================== */

.ds-header {
  position: relative;
  width: 100%;
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  font-family: var(--font-body);
  z-index: 1000;
}

.ds-header__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-8);
  height: 72px;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

/* ── Logo ── */
.ds-header__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
}
.ds-header__logo img {
  height: 36px;
  width: auto;
  display: block;
}

/* ── Desktop nav ── */
.ds-header__nav {
  flex: 1;
  display: flex;
  justify-content: center;
}
.ds-header__list {
  list-style: none;
  margin: 0;
  margin-bottom: 0 !important;
  padding: 0 !important;
  padding-left: 0 !important;
  display: flex;
  align-items: center;
  gap: var(--space-1);
}
/* Правка 4: фиксируем высоту айтемов чтобы не прыгал контейнер при открытии дропдауна */
.ds-header__item {
  position: relative;
  height: 38px;
  display: flex;
  align-items: center;
}

.ds-header__link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  height: 38px;
  font-family: var(--font-body);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-text-link);
  text-decoration: none;
  background: none;
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  white-space: nowrap;
  line-height: 1;
  transition: color var(--transition-base) !important, background var(--transition-base);
  /* Правка 4: блокируем влияние padding-изменения на высоту родителя */
  box-sizing: border-box;
}
.ds-header__link:link,
.ds-header__link:visited {
  color: var(--color-text-link) !important;
}

/* Правка 1: hover на обычных текст-линках */
.ds-header__nav .ds-header__item:not(#nav-zhilye):not(#nav-eshe) .ds-header__link:hover {
  color: var(--color-brand-500) !important;
  background: none;
}

.ds-header__link .ds-chev {
  width: 14px !important;
  height: 14px !important;
  min-width: 14px !important;
  min-height: 14px !important;
  max-width: 14px !important;
  max-height: 14px !important;
  flex-shrink: 0;
  transition: transform var(--transition-base);
}

/* Жильё и Ещё */
#nav-zhilye > .ds-header__link,
#nav-eshe   > .ds-header__link {
  color: var(--color-text-link);
}
#nav-zhilye > .ds-header__link:hover,
#nav-eshe   > .ds-header__link:hover {
  padding: var(--space-3) var(--space-6);
  background: var(--color-black);
  color: var(--color-text-inverse) !important;
}
.ds-header__item.is-open > .ds-header__link {
  padding: var(--space-3) var(--space-6);
  background: var(--color-black);
  color: var(--color-text-inverse) !important;
}
.ds-header__item.is-open > .ds-header__link:hover {
  color: var(--color-text-inverse) !important;
}
.ds-header__item.is-open > .ds-header__link .ds-chev {
  transform: rotate(180deg);
}

/* ── Dropdown base ── */
.ds-header__drop {
  display: none;
  position: absolute;
  top: calc(100% + var(--space-3));
  /* Правки 2 и 3: фон --color-neutral-600 */
  background: var(--color-neutral-600);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-2xl);
  padding: var(--space-3);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity var(--transition-base), transform var(--transition-base);
}
.ds-header__item.is-open .ds-header__drop {
  display: block;
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
/* Мост между триггером и дропдауном */
.ds-header__drop::before {
  content: '';
  position: absolute;
  top: calc(-1 * var(--space-3) - 2px);
  left: 0;
  right: 0;
  height: calc(var(--space-3) + 4px);
}

.ds-header__drop--rich {
  left: 0;
  width: 320px;
}
.ds-header__drop--simple {
  right: 0;
  width: 260px;
}

/* Rich item */
.ds-ddi {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-3);
  border-radius: var(--radius-xl);
  text-decoration: none !important;
  transition: filter var(--transition-base) !important;
}
.ds-ddi:hover {
  filter: brightness(1.35);
}
.ds-ddi__icon {
  width: 32px !important;
  height: 32px !important;
  min-width: 32px !important;
  min-height: 32px !important;
  max-width: 32px !important;
  max-height: 32px !important;
  flex-shrink: 0;
  color: var(--color-primary);
  margin-top: 2px;
}
.ds-ddi__title {
  font-size: var(--text-md);
  font-weight: var(--fw-semibold);
  color: var(--color-text-inverse) !important;
  line-height: 1.3;
  margin-bottom: var(--space-1);
}
.ds-ddi__desc {
  font-size: var(--text-sm);
  font-weight: var(--fw-regular);
  color: var(--color-text-faint);
  line-height: 1.45;
}

/* Simple link (Ещё) */
.ds-header__drop--simple .ds-ddl,
.ds-header__drop--simple .ds-ddl:link,
.ds-header__drop--simple .ds-ddl:visited {
  display: block;
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-md);
  font-weight: var(--fw-medium);
  color: var(--color-text-inverse) !important;
  text-decoration: none !important;
  border-radius: var(--radius-xl);
  /* Правка 3: hover — background --color-neutral-800 */
  transition: background var(--transition-base) !important, color var(--transition-base) !important;
}
.ds-header__drop--simple .ds-ddl:hover {
  color: var(--color-text-inverse) !important;
  background: var(--color-neutral-800);
  filter: none;
}

/* ── CTA ── */
.ds-header__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0 var(--space-5);
  height: 40px;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: var(--fw-semibold);
  background: var(--color-accent);
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  text-decoration: none !important;
  white-space: nowrap;
  flex-shrink: 0;
  opacity: 0.92;
  transition:
    opacity var(--transition-base),
    transform var(--transition-fast),
    box-shadow var(--transition-base) !important;
}
.ds-header__cta,
.ds-header__cta:link,
.ds-header__cta:visited {
  color: var(--color-text-inverse) !important;
}
.ds-header__cta:hover {
  color: var(--color-text-inverse) !important;
  opacity: 1;
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}
.ds-header__cta:active {
  transform: translateY(0);
  opacity: 0.88;
}
.ds-header__cta svg {
  width: 15px !important;
  height: 15px !important;
  min-width: 15px !important;
  min-height: 15px !important;
  max-width: 15px !important;
  max-height: 15px !important;
  flex-shrink: 0;
}

/* Правка 5: CTA в мобильной шапке (между лого и бургером) */
.ds-header__cta--mobile-inner {
  display: none;
}

/* ── Бургер ── */
.ds-header__burger {
  display: none;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  margin-left: auto;
  transition: background var(--transition-base);
  color: var(--color-text);
}
.ds-header__burger:hover {
  background: var(--color-surface-2);
}
/* Правка 6: иконка бургера через sprite */
.ds-header__burger svg {
  width: 20px !important;
  height: 14px !important;
  min-width: 20px !important;
  min-height: 14px !important;
  max-width: 20px !important;
  max-height: 14px !important;
}

/* ==========================================
   Overlay + Drawer
   ========================================== */
.ds-header__overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: var(--color-black);
  opacity: 0;
  z-index: 800;
  transition: opacity var(--transition-base);
  pointer-events: none;
}
.ds-header__overlay.is-visible {
  display: block;
  opacity: 0.5;
  pointer-events: auto;
}

.ds-header__drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: 75vw;
  max-width: 400px;
  height: 100vh;
  background: var(--color-bg);
  z-index: 900;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform var(--transition-slow);
  overflow: hidden;
}
.ds-header__drawer.is-open {
  transform: translateX(0);
}

/* Правка 7: шапка drawer — лого слева, кнопка закрыть справа */
.ds-drw-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-5);
  height: 64px;
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}
.ds-drw-top .ds-header__cta {
  background: var(--color-primary);
  height: 38px;
  padding: 0 var(--space-4);
  order: -1;
}
.ds-drw-top .ds-header__cta,
.ds-drw-top .ds-header__cta:link,
.ds-drw-top .ds-header__cta:visited,
.ds-drw-top .ds-header__cta:hover {
  color: var(--color-text-inverse) !important;
}
.ds-drw-top .ds-header__cta:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  opacity: 1;
}

.ds-drw-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text);
  border-radius: var(--radius-md);
  transition: background var(--transition-base);
  /* Правка 7: кнопка правее */
  order: 1;
  margin-left: auto;
}
.ds-drw-close:hover {
  background: var(--color-surface-2);
}
.ds-drw-close svg {
  width: 14px !important;
  height: 14px !important;
  min-width: 14px !important;
  min-height: 14px !important;
  max-width: 14px !important;
  max-height: 14px !important;
}

/* Скролл-область */
.ds-drw-body {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-2) 0 var(--space-8);
}

/* ── Аккордеон ── */
.ds-acc-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  /* Правки 8 и 10: padding-left 20px явно прописан */
  padding: var(--space-4) var(--space-5);
  padding-left: var(--space-5) !important;
  font-family: var(--font-body);
  font-size: var(--text-xl);
  font-weight: var(--fw-semibold);
  color: var(--color-text);
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  min-height: 56px;
  transition: color var(--transition-base);
}
.ds-acc-trigger:hover {
  color: var(--color-primary);
}
.ds-acc-trigger svg {
  width: 18px !important;
  height: 18px !important;
  min-width: 18px !important;
  min-height: 18px !important;
  max-width: 18px !important;
  max-height: 18px !important;
  flex-shrink: 0;
  transition: transform var(--transition-base);
}
.ds-acc-item.is-open .ds-acc-trigger svg {
  transform: rotate(180deg);
}
.ds-acc-body {
  display: none;
  /* Правки 8 и 10: padding-left 20px, явный !important против Tilda */
  padding: 0 var(--space-5) var(--space-4);
  padding-left: var(--space-5) !important;
  padding-right: var(--space-5) !important;
}
.ds-acc-item.is-open .ds-acc-body {
  display: block;
}

/* Обычная ссылка в drawer */
.ds-header__drawer .ds-mob-link,
.ds-header__drawer .ds-mob-link:link,
.ds-header__drawer .ds-mob-link:visited {
  display: flex;
